---
import astroLogo from '../assets/astro.svg';
import background from '../assets/background.svg';
import fazettenLogo from '../assets/fazetten_logo.svg';
---

<div id="container">
	<main id="background">
		<div id="wrappo">

			<section id="biglogo">
				<img id="logo" src={fazettenLogo.src} alt="Fazetten Logo" />
		</section>
		<section id="hero">
			<div id="contento">
				<!-- <div id="titletext">
					<h1>
						Ab Frühjahr 2026: das neue Onlinemagazin für Inklusion
						</h1>
						</div> -->
						<div id="subtitletext">
							<h1>
								<!-- Wir stellen die Menschen, ihre Geschichten und die Vielfalt der Gesellschaft in den Fokus. 
								Unsere Beiträge beleuchten die fünf Spannungsfelder von jung und alt, 
								arm und reich, leben mit und ohne Behinderung, unterschiedliche Herkunft sowie all Genders – 
								und selbstverständlich deren Schnittmengen. Fazetten schafft einen Ort für Geschichten, 
								die ungehört bleiben, und Themen, die übersehen werden. Fazetten, die Schweizer Stimme für Vielfalt. -->
								
								Unsere Webseite ist aktuell im Umbau. Ab dem 16. März 2026 sind wir mit unserem neuen Onlinemagazin für eine vielfältige und inklusive Schweiz wieder für Sie da.
								Wir freuen uns darauf, Sie bald auf unserer neuen Plattform begrüssen zu dürfen!
							</h1>
						</div>
					</div>
				</section>
			</div>

	</main>

</div>

<style>
	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		/* filter: blur(100px); */
		background: #798D60;
		background: linear-gradient(180deg,rgba(121, 141, 96, 1) 24%, rgba(255, 255, 255, 1) 100%);
	}

	#logo {
		width: 100%;
		min-height: 50%;
		/* max-width: 1200px; */
		/* max-height: 400px; */
	}

	#contento {
		display: flex;
		/* flex-direction: column; */
	}

	#container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100%;
	}

	#titletext {
		h1 {

			font-size: 64px;
		}
	}

	#subtitletext {
		h1 {
			font-size: 34px;
			font-weight: 200;
			font-style: normal;
		}
		p {
			font-size: 32px;
		}
	}

	main {
		height: 100%;
		width: 100%;
		display: flex;
		justify-content: center;
		/* justify-content: flex-start; */
		/* flex-direction: column; */
		/* max-width: 1200px; */
	}

	#wrappo {
		max-width: 1440px;
		justify-content: center;
		align-items: center;
		/* width: 100%; */
	}

	#biglogo {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 16px;
		padding-top: 100px;
	}

	#hero {
		display: flex;
		align-items: start;
		flex-direction: column;
		justify-content: center;
		padding: 100px;

		p {
			font-size: 24px;
		}
	}

	h1 {
		font-size: 22px;
		margin-top: 0.25em;
	}

	#links {
		display: flex;
		gap: 16px;
	}

	#links a {
		display: flex;
		align-items: center;
		padding: 10px 12px;
		color: #111827;
		text-decoration: none;
		transition: color 0.2s;
	}

	#links a:hover {
		color: rgb(78, 80, 86);
	}

	#links a svg {
		height: 1em;
		margin-left: 8px;
	}

	#links a.button {
		color: white;
		background: linear-gradient(83.21deg, #3245ff 0%, #bc52ee 100%);
		box-shadow:
			inset 0 0 0 1px rgba(255, 255, 255, 0.12),
			inset 0 -2px 0 rgba(0, 0, 0, 0.24);
		border-radius: 10px;
	}

	#links a.button:hover {
		color: rgb(230, 230, 230);
		box-shadow: none;
	}

	pre {
		font-family:
			ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, Consolas, 'DejaVu Sans Mono',
			monospace;
		font-weight: normal;
		background: linear-gradient(14deg, #d83333 0%, #f041ff 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		margin: 0;
	}

	h2 {
		margin: 0 0 1em;
		font-weight: normal;
		color: #111827;
		font-size: 20px;
	}

	p {
		color: #4b5563;
		font-size: 16px;
		line-height: 24px;
		letter-spacing: -0.006em;
		margin: 0;
	}

	code {
		display: inline-block;
		background:
			linear-gradient(66.77deg, #f3cddd 0%, #f5cee7 100%) padding-box,
			linear-gradient(155deg, #d83333 0%, #f041ff 18%, #f5cee7 45%) border-box;
		border-radius: 8px;
		border: 1px solid transparent;
		padding: 6px 8px;
	}

	.box {
		padding: 16px;
		background: rgba(255, 255, 255, 1);
		border-radius: 16px;
		border: 1px solid white;
	}

	#news {
		position: absolute;
		bottom: 16px;
		right: 16px;
		max-width: 300px;
		text-decoration: none;
		transition: background 0.2s;
		backdrop-filter: blur(50px);
	}

	#news:hover {
		background: rgba(255, 255, 255, 0.55);
	}

	@media screen and (max-height: 368px) {
		#news {
			display: none;
		}
	}

	@media screen and (max-width: 768px) {
		#container {
			display: flex;
			flex-direction: column;
			align-items: start;
			justify-content: flex-start;
		}

		#logo {
			/* max-height: 10%; */
		}

		#subtitletext {
		h1 {
			font-size: 24px;
			font-weight: 600;
			/* text-align: center; */
			/* font-style: normal; */
		}
		p {
			font-size: 32px;
		}
	}

	#biglogo {
			padding-top: 50px;
		}

		#hero {
			display: block;
			padding: 20px;
			padding-top: 10%;
		}

		#links {
			flex-wrap: wrap;
		}

		#links a.button {
			padding: 14px 18px;
		}

		#news {
			right: 16px;
			left: 16px;
			bottom: 2.5rem;
			max-width: 100%;
		}

		h1 {
			line-height: 1.5;
		}
	}
</style>
